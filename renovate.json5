{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchDepTypes": ["dependencies", "build-dependencies", "workspace.dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "cargo non-major runtime dependencies",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["cargo"],
      "matchDepTypes": ["dev-dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "cargo non-major development dependencies",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "groupName": "github-actions non-major updates",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    }
  ]
}
